{
  "version": 2,
  "outputDirectory": "dist",
  "buildCommand": "npm run build",
  "cleanUrls": true,
  "functions": {
    "api/**/*.ts": {
      "includeFiles": "{src/**,firebase-applet-config.json,dist/**}"
    }
  },
  "redirects": [
    {
      "source": "/(.*\\.(php|env|yml|yaml|ini|conf|log|sql|tar|gz|zip|bak|git|rsa|aspx|asp|jsp|cgi|pl|py|sh|exe|dll|md))",
      "destination": "https://localhost/",
      "statusCode": 301
    }
  ],
  "rewrites": [
    { "source": "/api/v1/secure-fetch", "destination": "/api/index" },
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/sitemap.xml", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/api/index" }
  ]
}
