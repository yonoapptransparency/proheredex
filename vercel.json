{
  "version": 2,
  "cleanUrls": true,
  "functions": {
    "api/**/*.ts": {
      "includeFiles": "{src/**,firebase-applet-config.json,dist/**}"
    }
  },
  "rewrites": [
    { "source": "/api/v1/secure-fetch", "destination": "/api/index.ts" },
    { "source": "/api/(.*)", "destination": "/api/index.ts" },
    { "source": "/sitemap.xml", "destination": "/api/index.ts" },
    { "source": "/(.*)", "destination": "/api/index.ts" }
  ]
}
