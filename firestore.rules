rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow public read on all documents
    match /{document=**} {
      allow read: if true;
    }
    
    // Allow write access ONLY for the specific admin email
    match /{document=**} {
      allow write: if request.auth != null && 
                    (request.auth.token.email == 'defentechscholar@gmail.com' ||
                     request.auth.token.email.lower() == 'defentechscholar@gmail.com');
    }
  }
}
