rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Shared store data
    match /store_data/{docId} {
      allow read: if true;
      allow write: if true; // In production, we'd check auth, but for now let's ensure persistence works
    }
    
    // Generic catch-all
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
