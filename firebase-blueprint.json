{
  "entities": {
    "AppConfig": {
      "title": "App Configuration",
      "description": "Configuration for a single app in the store",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "icon_url": { "type": "string" },
        "category": { "type": "string" },
        "version": { "type": "string" },
        "file_size": { "type": "string" },
        "developer": { "type": "string" },
        "encrypted_download_url": { "type": "string" },
        "description_html": { "type": "string" },
        "safety_status": { "type": "string", "enum": ["Verified", "Caution", "Unsafe"] },
        "serial_number": { "type": "number" },
        "is_new": { "type": "boolean" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "slug"]
    },
    "GlobalSettings": {
      "title": "Global Settings",
      "description": "Overall site configuration",
      "type": "object",
      "properties": {
        "site_title": { "type": "string" },
        "meta_description": { "type": "string" },
        "logo_url": { "type": "string" },
        "categories": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "firestore": {
    "/store_data/apps": {
      "schema": "AppConfig",
      "description": "List of apps (stored as { items: [] })"
    },
    "/store_data/settings": {
      "schema": "GlobalSettings",
      "description": "Site-wide settings"
    },
    "/store_data/news": {
      "schema": "object",
      "description": "News items"
    },
    "/store_data/blogs": {
      "schema": "object",
      "description": "Blog posts"
    },
    "/store_data/videos": {
      "schema": "object",
      "description": "Video links"
    }
  }
}
