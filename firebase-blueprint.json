{
  "entities": {
    "StoreDataApps": {
      "title": "Apps Collection Wrapper",
      "description": "A wrapper for the list of apps",
      "type": "object",
      "properties": {
        "items": {
          "type": "array",
          "description": "List of AppConfig objects"
        }
      },
      "required": ["items"]
    },
    "StoreDataSettings": {
      "title": "Global Settings",
      "description": "Global application settings",
      "type": "object",
      "properties": {
        "site_title": { "type": "string" },
        "meta_description": { "type": "string" },
        "logo_url": { "type": "string" },
        "favicon_url": { "type": "string" },
        "helpline_whatsapp": { "type": "string" },
        "helpline_telegram": { "type": "string" },
        "support_email": { "type": "string" },
        "disclaimer_text": { "type": "string" },
        "ethics_discrimination_text": { "type": "string" },
        "ticker_text": { "type": "string" },
        "animations_enabled": { "type": "boolean" },
        "categories": { "type": "array" },
        "banners": { "type": "array" }
      },
      "required": ["site_title"]
    },
    "StoreDataNews": {
      "title": "News Collection",
      "description": "A wrapper for news items",
      "type": "object",
      "properties": {
        "items": { "type": "array" }
      },
      "required": ["items"]
    },
    "StoreDataBlogs": {
      "title": "Blog Collection",
      "description": "A wrapper for blog items",
      "type": "object",
      "properties": {
        "items": { "type": "array" }
      },
      "required": ["items"]
    },
    "StoreDataVideos": {
      "title": "Video Collection",
      "description": "A wrapper for video items",
      "type": "object",
      "properties": {
        "items": { "type": "array" }
      },
      "required": ["items"]
    }
  },
  "firestore": {
    "/store_data/apps": {
      "schema": "StoreDataApps",
      "description": "Application configurations"
    },
    "/store_data/settings": {
      "schema": "StoreDataSettings",
      "description": "Global site settings"
    },
    "/store_data/news": {
      "schema": "StoreDataNews",
      "description": "News items"
    },
    "/store_data/blogs": {
      "schema": "StoreDataBlogs",
      "description": "Blog posts"
    },
    "/store_data/videos": {
      "schema": "StoreDataVideos",
      "description": "Video gallery"
    }
  }
}
